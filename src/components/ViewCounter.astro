---
interface Props {
  slug: string;
  increment?: boolean;
  class?: string;
}
const { slug, increment = false, class: className } = Astro.props;
---

<span
  class:list={["view-counter inline-flex items-center gap-1", className]}
  data-slug={slug}
  data-increment={increment ? "1" : "0"}
  hidden
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
    <circle cx="12" cy="12" r="3"></circle>
  </svg>
  <span class="view-count tabular-nums">–</span>
  <span class="sr-only">views</span>
</span>

<script>
  for (const el of document.querySelectorAll<HTMLElement>(".view-counter")) {
    const slug = el.dataset.slug;
    if (!slug) continue;
    let increment = el.dataset.increment === "1";

    // Count each post at most once per browser session.
    const seenKey = `viewed:${slug}`;
    if (increment && sessionStorage.getItem(seenKey)) increment = false;

    (async () => {
      try {
        const res = increment
          ? await fetch("/api/views", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ slug }),
            })
          : await fetch(`/api/views?slug=${encodeURIComponent(slug)}`);
        const data = (await res.json()) as { views?: number | null };
        if (data && typeof data.views === "number") {
          const countEl = el.querySelector(".view-count");
          if (countEl)
            countEl.textContent = new Intl.NumberFormat().format(data.views);
          if (increment) sessionStorage.setItem(seenKey, "1");
          el.hidden = false; // reveal only once we have a real count
        }
      } catch {
        /* KV unavailable or offline — leave the counter hidden */
      }
    })();
  }
</script>
