---
interface Props {
  type: "person" | "blogPost" | "website" | "breadcrumb";
  data?: any;
}

const { type, data } = Astro.props;

let structuredData = {};

if (type === "person") {
  // Person/ProfilePage schema for homepage
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Joseph Ju",
    url: "https://heyjoseph.me",
    jobTitle: "Full-Stack Developer",
    worksFor: {
      "@type": "Organization",
      name: "Freelance",
    },
    address: {
      "@type": "PostalAddress",
      addressLocality: "Tokyo",
      addressCountry: "JP",
    },
    sameAs: [
      "https://github.com/heyjosephme",
      "https://x.com/heyjosephme",
      "https://www.linkedin.com/in/tokyojoseph/",
    ],
    knowsAbout: [
      "Ruby on Rails",
      "JavaScript",
      "TypeScript",
      "React",
      "Hotwire",
      "Web Development",
    ],
  };
} else if (type === "blogPost" && data) {
  // BlogPosting schema for blog posts
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    datePublished: data.publishedAt,
    dateModified: data.updatedAt || data.publishedAt,
    author: {
      "@type": "Person",
      name: "Joseph Ju",
      url: "https://heyjoseph.me",
    },
    publisher: {
      "@type": "Person",
      name: "Joseph Ju",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    image: data.image || "https://heyjoseph.me/og-image.png",
    keywords: data.categories?.join(", "),
  };
} else if (type === "website") {
  // WebSite schema for the homepage (site-wide identity)
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Joseph Ju",
    url: "https://heyjoseph.me",
    description:
      "Full-stack developer in Tokyo — Rails 8 + Hotwire, TypeScript, and React.",
    inLanguage: "en",
    author: {
      "@type": "Person",
      name: "Joseph Ju",
      url: "https://heyjoseph.me",
    },
  };
} else if (type === "breadcrumb" && data?.items) {
  // BreadcrumbList schema (Home is prepended automatically)
  const site = "https://heyjoseph.me";
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
      ...data.items.map(
        (item: { label: string; href?: string }, i: number) => ({
          "@type": "ListItem",
          position: i + 2,
          name: item.label,
          ...(item.href ? { item: new URL(item.href, site).toString() } : {}),
        })
      ),
    ],
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
